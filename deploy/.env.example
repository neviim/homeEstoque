# ─────────────────────────────────────────────────────────────────────────────
# HomeEstoque — variáveis de ambiente para deploy Docker
# Copie este arquivo para .env na raiz do projeto e preencha os valores.
# O install.sh faz isso automaticamente de forma interativa.
# ─────────────────────────────────────────────────────────────────────────────

# Versão do release a usar.
# "latest" → sempre a versão mais recente publicada.
# Use "v0.1.1" (ou outra tag) para fixar uma versão específica.
VERSION=latest

# Secret para assinar tokens JWT.
# OBRIGATÓRIO. Qualquer pessoa que o tenha pode forjar sessões.
# Gere um segredo forte: openssl rand -hex 32
JWT_SECRET=

# ─── HTTPS com Caddy (opcional) ───────────────────────────────────────────────
# Deixe DOMAIN vazio para rodar em modo local (HTTP, porta HTTP_PORT).
# Quando preenchido, o Caddy emite certificado Let's Encrypt automaticamente.
# Requisito: porta 80 e 443 abertas e DNS do domínio apontando para este IP.
DOMAIN=

# Email para avisos de renovação do certificado Let's Encrypt.
# Necessário apenas quando DOMAIN está preenchido.
LETSENCRYPT_EMAIL=

# ─── Configuração local (sem HTTPS) ───────────────────────────────────────────
# Porta exposta no host quando NÃO estiver usando Caddy.
# Com Caddy ativo (DOMAIN preenchido), esta variável é ignorada.
HTTP_PORT=8080

# Origens permitidas pelo CORS.
# Sem HTTPS: http://localhost:${HTTP_PORT} ou http://<IP-LAN>:${HTTP_PORT}
# Com HTTPS: https://${DOMAIN}
CORS_ORIGINS=http://localhost:8080
